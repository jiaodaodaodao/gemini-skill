# ---- Browser ----
BROWSER_PATH=
BROWSER_DEBUG_PORT=40821
BROWSER_USER_DATA_DIR=
BROWSER_HEADLESS=false
BROWSER_PROTOCOL_TIMEOUT=60000
OUTPUT_DIR=./gemini-image

# ---- Business2API ----
BUSINESS_MODE=false
BUSINESS_BASE_URL=
BUSINESS_API_KEY=
BUSINESS_MODEL=gemini-2.5-flash
BUSINESS_IMAGE_MODEL=gemini-imagen
# 例如：cfmail----you@example.com----jwtToken
BUSINESS_ACCOUNT=

# ---- Proxy ----
PROXY_POOL=
PROXY_STRATEGY=round_robin

# ---- Daemon ----
DAEMON_PORT=40225
DAEMON_HOST=127.0.0.1
DAEMON_TOKEN=
# 逗号分隔，例如：127.0.0.1,10.0.0.8
DAEMON_ALLOWED_IPS=
DAEMON_TTL_MS=1800000
